# ---------------------------------------------------------------------------
# Azure Database for PostgreSQL (Flexible Server)
# Copy this file to `.env.local` and fill in your real values.
# ---------------------------------------------------------------------------

# Full connection string (used by the app). sslmode=require is mandatory on Azure.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.postgres.database.azure.com:5432/DATABASE?sslmode=require"

# Individual parts (optional — handy for psql / tooling). Keep in sync with DATABASE_URL.
PGHOST="HOST.postgres.database.azure.com"
PGPORT="5432"
PGUSER="USER"
PGPASSWORD="PASSWORD"
PGDATABASE="DATABASE"
PGSSLMODE="require"

# ---------------------------------------------------------------------------
# Admin bootstrap account (seeded once via: npm run db:seed:admin)
# This is the only admin — it is not created through the signup flow.
# ---------------------------------------------------------------------------
ADMIN_NAME="Platform Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="a-strong-password"
